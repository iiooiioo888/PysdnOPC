# =============================================================================
# OpenOPC Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in the values you need.
#   cp .env.example .env
#
# The `.env` file is git-ignored. NEVER commit secrets to version control.
# After running `opc init`, configs live in `.opc/config/`.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM API Key (Required)
# -----------------------------------------------------------------------------
# OpenOPC uses litellm for model routing. Set the key for your chosen provider.
# Configure `api_key_env` in `.opc/config/llm_config.yaml` to point at the
# variable name below, OR set `api_key` directly in that YAML (not recommended).
#
# Default config uses DeepSeek (https://platform.deepseek.com/api_keys):
DEEPSEEK_API_KEY=

# Alternative providers — set whichever matches your `default_model` in
# llm_config.yaml. Only ONE key is required:
# DASHSCOPE_API_KEY=         # https://dashscope.console.aliyun.com (Qwen/通義千問)
# QWEN_API_KEY=              # Alias for DASHSCOPE_API_KEY
# OPENAI_API_KEY=            # https://platform.openai.com/api-keys
# ANTHROPIC_API_KEY=         # https://console.anthropic.com/settings/keys
# AZURE_OPENAI_API_KEY=      # Azure OpenAI resource key
# AZURE_API_KEY=             # Azure AI Services key
# GEMINI_API_KEY=            # https://aistudio.google.com/apikey
# GOOGLE_API_KEY=            # Google AI / Vertex AI
# MISTRAL_API_KEY=           # https://console.mistral.ai/api-keys
# GROQ_API_KEY=              # https://console.groq.com/keys
# TOGETHERAI_API_KEY=        # https://api.together.xyz/settings/api-keys
# ARK_API_KEY=               # Volcengine Ark (ByteDance)
# OPENROUTER_API_KEY=        # https://openrouter.ai/keys

# -----------------------------------------------------------------------------
# OPC Home Directory (Optional)
# -----------------------------------------------------------------------------
# Override the default OPC data directory (~/.opc or ./.opc).
# Corresponds to `system.opc_home` in system_config.yaml.
# OPC_HOME=/path/to/custom/.opc

# -----------------------------------------------------------------------------
# SkillHub Remote Skills (Optional)
# -----------------------------------------------------------------------------
# Enables remote skill search/promotion. Corresponds to
# `capabilities.skillhub.api_key_env` in system_config.yaml.
# Get a key at https://www.skillhub.club
# SKILLHUB_API_KEY=

# -----------------------------------------------------------------------------
# MCP Servers (Optional)
# -----------------------------------------------------------------------------
# Used by MCP server entries in system_config.yaml `mcp_servers[].env`.
# Example: GitHub MCP server (uncomment the github block in system_config.yaml).
# GITHUB_TOKEN=              # https://github.com/settings/tokens

# -----------------------------------------------------------------------------
# External Agent Overrides (Optional)
# -----------------------------------------------------------------------------
# These override auto-detection of external coding agents.
# Corresponds to `external_agents` in agent_config.yaml.

# Codex CLI home directory (login/session state):
# CODEX_HOME=

# OpenCode binary path (if not on PATH):
# OPENCODE_BIN=

# OpenCode config directory (skills, settings):
# OPENCODE_CONFIG_DIR=

# XDG config home fallback (Linux/macOS):
# XDG_CONFIG_HOME=

# -----------------------------------------------------------------------------
# Channel Tokens (Optional — configure in channel_config.yaml)
# -----------------------------------------------------------------------------
# Channel credentials are read from `.opc/config/channel_config.yaml` directly.
# If you prefer env-var injection (e.g. Docker / CI), export them and reference
# via YAML anchors or a secrets manager. Common ones:

# Telegram Bot token — https://t.me/BotFather
# TELEGRAM_BOT_TOKEN=

# Discord Bot token — https://discord.com/developers/applications
# DISCORD_BOT_TOKEN=

# Slack tokens — https://api.slack.com/apps
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=

# Feishu (Lark) — https://open.feishu.cn/app
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=

# DingTalk — https://open-dev.dingtalk.com
# DINGTALK_CLIENT_ID=
# DINGTALK_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Internal Runtime (set automatically by the engine — do NOT set manually)
# -----------------------------------------------------------------------------
# These are injected into external-agent subprocesses for collaboration RPC.
# Listed here for debugging/reference only.

# OPC_COLLAB_RPC_TRANSPORT=   # rpc transport: stdio | tcp
# OPC_COLLAB_RPC_PATH=        # unix socket / named pipe path
# OPC_COLLAB_RPC_HOST=        # tcp host
# OPC_COLLAB_RPC_PORT=        # tcp port
# OPC_COLLAB_RPC_TOKEN=       # shared auth token
# OPC_PROJECT_DB_PATH=        # SQLite DB path for the project
# OPC_TASK_ID=                # current task identifier
# OPC_WORKSPACE_ROOT=         # workspace root for file operations
# OPC_COMMS_FROM=             # sender role id
# OPC_COMMS_PROJECT=          # project id for messaging
# OPC_COMMS_SESSION=          # session id for messaging
# OPC_COLLAB_PROFILE=         # collaboration tool profile
# OPC_ALLOWED_COLLAB_TOOLS=   # JSON list of permitted collab tools
# OPC_EXTERNAL_AGENT_TRACE=   # set to "1" for verbose agent tracing
# OPC_EXTERNAL_CANCEL_STACK=  # internal cancellation signal
